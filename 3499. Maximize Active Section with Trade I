class Solution {
public:
    int maxActiveSectionsAfterTrade(string s) {
        int n = s.size();

        int totalOnes = 0;
        int maxGain = 0;

        int prevZero = INT_MIN;

        for (int i = 0; i < n;) {
            int j = i;

            while (j < n && s[j] == s[i])
                j++;

            int len = j - i;

            if (s[i] == '1') {
                totalOnes += len;
            } else {
                maxGain = max(maxGain, prevZero + len);
                prevZero = len;
            }

            i = j;
        }

        return totalOnes + maxGain;
    }
};
