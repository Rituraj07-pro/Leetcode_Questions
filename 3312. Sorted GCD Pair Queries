class Solution {
public:
    vector<int> gcdValues(vector<int>& nums, vector<long long>& queries) {
        int mx = *max_element(nums.begin(), nums.end());

        vector<int> freq(mx + 1, 0);
        for (int x : nums)
            freq[x]++;

        // cnt[d] = numbers divisible by d
        vector<long long> cnt(mx + 1, 0);

        for (int d = 1; d <= mx; d++) {
            for (int j = d; j <= mx; j += d)
                cnt[d] += freq[j];
        }

        // exactPairs[d] = pairs having gcd exactly d
        vector<long long> exactPairs(mx + 1, 0);

        for (int d = mx; d >= 1; d--) {
            long long c = cnt[d];
            exactPairs[d] = c * (c - 1) / 2;

            for (int j = 2 * d; j <= mx; j += d)
                exactPairs[d] -= exactPairs[j];
        }

        // prefix over gcd values
        vector<long long> pref(mx + 1, 0);
        for (int d = 1; d <= mx; d++)
            pref[d] = pref[d - 1] + exactPairs[d];

        vector<int> ans;

        for (long long q : queries) {
            int l = 1, r = mx;

            while (l < r) {
                int mid = (l + r) / 2;

                if (pref[mid] > q)
                    r = mid;
                else
                    l = mid + 1;
            }

            ans.push_back(l);
        }

        return ans;
    }
};
